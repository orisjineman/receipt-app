# --- Server ---
NODE_ENV=development
PORT=4000

# --- Database (Neon Postgres) ---
# Vercel-Neon 자동 연동을 쓰면 두 값이 자동 주입된다.
# 로컬 .env 에는 Vercel 대시보드 > Storage > Neon > .env 탭의 값을 그대로 복붙.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# 마이그레이션용 unpooled URL (long-lived connection 필요)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# --- Basic Auth (단일 사용자) ---
# 프론트엔드의 BASIC_AUTH_USER / BASIC_AUTH_PASSWORD 와 동일하게 맞출 것.
BASIC_AUTH_USER="me"
BASIC_AUTH_PASSWORD="여기에-충분히-긴-비밀번호 (16자 이상 권장)"

# --- Vercel Blob ---
# Vercel 대시보드 > Storage > Blob > .env.local 탭에서 복사
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx"

# --- Upstage Document OCR ---
# https://console.upstage.ai/ 에서 API Key 발급
UPSTAGE_API_KEY="up_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
UPSTAGE_OCR_URL="https://api.upstage.ai/v1/document-ai/ocr"

# --- CORS ---
# 쉼표로 여러 origin 지정 가능. 프론트엔드 rewrites 방식이라 일반적으로 동일 origin이지만,
# 직접 호출하는 케이스(curl 테스트 등)도 허용하려면 추가.
CORS_ORIGINS="http://localhost:3000"
